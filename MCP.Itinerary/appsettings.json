{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false,connectTimeout=2000"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "itinerary.day-events",
    "GroupId": "itinerary-indexer"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "Index": "itinerary-days"
  }
}
