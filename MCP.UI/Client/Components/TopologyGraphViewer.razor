@namespace MCP.UI.Components
@using MCP.Core.Models

@code {
    [Parameter] public List<IssueNode> Nodes { get; set; } = new();
    [Parameter] public EventCallback<IssueNode> OnNodeSelected { get; set; }

    string GetStatusColor(string status) => status switch
    {
        "Healthy" => "green",
        "Degraded" => "orange",
        "Error" => "red",
        _ => "gray"
    };
}

<div class="topology-grid">
    @foreach (var node in Nodes)
    {
        <div class="node-card"
             style="border-left: 5px solid @GetStatusColor(node.Status);"
             @onclick="@(() => OnNodeSelected.InvokeAsync(node))">
            <h4>@node.Name</h4>
            <p>
                Status:
                <span style="color:@GetStatusColor(node.Status)">
                    @node.Status
                    @(node.Status == "Healthy" ? "✅" : node.Status == "Degraded" ? "⚠️" : "❌")
                </span>
            </p>
            <p>Code Path: @node.LinkedCodePath</p>
        </div>
    }
</div>
